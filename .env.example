# Supabase PostgreSQL transaction-pooler URL. Keep sslmode=require in the URL.
# Without DATABASE_URL, the app falls back to temporary in-memory storage.
DATABASE_URL=

# Keep the serverless connection pool small. Valid range: 1-10.
DATABASE_POOL_MAX=5

# Optional: enables OpenAI-powered chat. Without it, NephroBot uses the
# repository's built-in educational kidney-health responses.
OPENAI_API_KEY=
